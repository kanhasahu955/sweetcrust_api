# backend_v2 credentials — copy to .env and fill in.
# This stack is independent of legacy backend/.

APP_NAME=SweetCrust Bakery
ENV=development
HOST=0.0.0.0
# Monolith-style PORT is ignored by services; use SERVICE_PORT / uvicorn --port.
PORT=8000
RELOAD=true
LOG_LEVEL=INFO
LOG_JSON=false

DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/sweetcrust

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

OTP_EXPIRE_MINUTES=10
OTP_DEV_CODE=123456

CORS_ORIGINS=*
UPLOAD_DIR=uploads

REDIS_URL=

BAKERY_NAME=SweetCrust Bakery
BAKERY_PHONE=+919876543210
BAKERY_GSTIN=
BAKERY_UPI_ID=sweetcrust@upi

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=SweetCrust Bakery
MAIL_FROM_EMAIL=
AUTH_PUBLIC_BASE_URL=http://127.0.0.1:8080
AUTH_MAIL_NOTIFY_ON_LOGIN=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
GROQ_API_KEY=
PINECONE_API_KEY=

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

DELIVERY_RADIUS_KM=100
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=SWEETCRUST
