# SweetCrust backend_v2 — PRODUCTION (Hostinger VPS)
# Copy to .env.production on the server and fill every CHANGE_ME value.
# Never commit .env.production.

APP_NAME=SweetCrust Bakery
ENV=production
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- MySQL (docker-compose.prod.yml mysql service) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_LONG_RANDOM
MYSQL_DATABASE=sweetcrust
MYSQL_USER=sweetcrust
MYSQL_PASSWORD=CHANGE_ME_APP_LONG_RANDOM
# Services also get DATABASE_URL injected by compose; keep this in sync if you override:
DATABASE_URL=mysql+pymysql://sweetcrust:CHANGE_ME_APP_LONG_RANDOM@mysql:3306/sweetcrust

# --- Redis (injected by compose; optional override) ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=10
# Leave empty in production — never ship a fixed OTP.
OTP_DEV_CODE=

# Public API origin (no trailing slash)
AUTH_PUBLIC_BASE_URL=https://api.bakerywala.cloud
AUTH_MAIL_NOTIFY_ON_LOGIN=false

# Lock CORS to real frontends (comma-separated, no spaces or with spaces — match your package parser)
CORS_ORIGINS=https://admin.bakerywala.cloud,https://store.bakerywala.cloud,https://bakerywala.cloud,https://www.bakerywala.cloud

UPLOAD_DIR=uploads

BAKERY_NAME=SweetCrust Bakery
BAKERY_PHONE=+919876543210
BAKERY_GSTIN=
BAKERY_UPI_ID=

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=SweetCrust Bakery
MAIL_FROM_EMAIL=

# --- Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# --- LLM / AI ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
GROQ_API_KEY=
PINECONE_API_KEY=

# --- ImageKit ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Delivery / SMS ---
DELIVERY_RADIUS_KM=100
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=SWEETCRUST

# --- TLS / deploy helpers ---
API_DOMAIN=api.bakerywala.cloud
CERTBOT_EMAIL=CHANGE_ME@yourdomain.com
DEPLOY_HOST=145.223.21.127
DEPLOY_USER=root
DEPLOY_PATH=/opt/sweetcrust/backend_v2
